# ------------------------------
# Core API
# ------------------------------
API_HOST=127.0.0.1
API_PORT=8000
AUTH_PASSWORD_SALT=change_me_to_a_random_secret

# ------------------------------
# Reasoning Layer
# ------------------------------
GEMINI_API_KEY=your_gemini_api_key

# ------------------------------
# OCR Provider: Google Document AI
# ------------------------------
GOOGLE_DOCUMENT_AI_PROJECT_ID=your_gcp_project_id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your_processor_id
GOOGLE_DOCUMENT_AI_API_KEY=your_document_ai_api_key

# ------------------------------
# OCR Provider: AWS Textract
# ------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ------------------------------
# OCR Provider: Azure Document Intelligence
# ------------------------------
AZURE_DOCINT_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
AZURE_DOCINT_API_KEY=your_azure_docint_api_key
AZURE_DOCINT_API_VERSION=2024-07-31-preview

# ------------------------------
# Queue / Worker
# ------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ------------------------------
# MongoDB Atlas
# ------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=idp
MONGODB_VECTOR_INDEX=vector_index
