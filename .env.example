# ============================================================
# DOC-INTEL AI Backend – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The .env file is intentionally git-ignored so that secrets
# are never committed to version control.
# ============================================================

# ----------------------------------------------------------
# MongoDB Atlas connection string (REQUIRED for auth & docs)
# ----------------------------------------------------------
# Format for MongoDB Atlas:
#   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# You can find this string in the Atlas UI:
#   Cluster → Connect → Connect your application → Python driver
#
# Example (replace the placeholders with your real values):
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/idp?retryWrites=true&w=majority
#
# IMPORTANT: You must also whitelist this machine's IP in MongoDB Atlas:
#   Atlas → Network Access → Add IP Address
#   Use 0.0.0.0/0 for development, or add your exact IP for production.
#   Connections fail with an SSL error if your IP is NOT whitelisted.
#
# For local development / testing without a real MongoDB instance,
# leave this blank (or set it to "mongomock://") to use the built-in
# in-memory MongoDB backend powered by mongomock.  Data is NOT
# persisted between server restarts when using the in-memory backend.
MONGODB_URI=

# Name of the MongoDB database (default: idp)
MONGODB_DB_NAME=idp

# Atlas Vector Search index name (required for semantic search endpoint)
MONGODB_VECTOR_INDEX=vector_index

# ----------------------------------------------------------
# Authentication / Security
# ----------------------------------------------------------
# A random secret string used to salt password hashes and
# sign auth tokens.  Change this to a long random value in
# production and never commit it to git.
#
# Example: openssl rand -hex 32
AUTH_PASSWORD_SALT=docintel_default_salt

# Maximum lifetime of an issued auth token in seconds.
# Default: 604800 (7 days)
AUTH_TOKEN_MAX_AGE_SECONDS=604800

# ----------------------------------------------------------
# AI / OCR Provider Keys (optional – leave blank to use
# the built-in local engines)
# ----------------------------------------------------------
# Google Gemini API key (required for cloud/enterprise reasoning layer)
GEMINI_API_KEY=

# OpenAI API key (optional – for OpenAI GPT-4o cloud OCR path)
OPENAI_API_KEY=

# ----------------------------------------------------------
# Google Document AI (enterprise OCR provider: documentai)
# ----------------------------------------------------------
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_API_KEY=

# ----------------------------------------------------------
# AWS Textract (enterprise OCR provider: textract)
# ----------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ----------------------------------------------------------
# Azure AI Document Intelligence (enterprise OCR: azure)
# ----------------------------------------------------------
AZURE_DOCINT_ENDPOINT=
AZURE_DOCINT_API_KEY=
AZURE_DOCINT_API_VERSION=2024-07-31-preview

# ----------------------------------------------------------
# ----------------------------------------------------------
# Google Service Account / Vertex AI (required for Imagen)
# ----------------------------------------------------------
# Path to your downloaded service account JSON key file.
# Used for Vertex AI Imagen image generation.
# NEVER commit this file to git — it is listed in .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# Google Cloud project and region (from the service account JSON)
GOOGLE_CLOUD_PROJECT=document-ai-487512
GOOGLE_CLOUD_LOCATION=us-central1

# ----------------------------------------------------------
# Celery / Redis (optional – only needed if using async tasks)
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
